# Instagram credentials — set these as Railway environment variables, never commit
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Database URL — Railway PostgreSQL service provides this automatically
# For local SQLite dev:
DATABASE_URL=sqlite:///./igtoxic.db

# Cookie storage path (worker container only)
COOKIES_PATH=/data/ig_session.json

# Scan interval in minutes (default 90–120)
SCAN_INTERVAL_MIN=90
SCAN_INTERVAL_MAX=120
