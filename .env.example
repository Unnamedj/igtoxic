# Cuenta que hace el login (puede ser una cuenta secundaria/espía)
IG_USERNAME=cuenta_espia
IG_PASSWORD=password_cuenta_espia

# Cuenta a monitorear (tu perfil principal)
# Si no se define, monitorea la misma cuenta del login
IG_TARGET=ilyiinx

# Base de datos — Railway PostgreSQL lo llena automático
# Para dev local con SQLite:
DATABASE_URL=sqlite:///./igtoxic.db

# Ruta de cookies de sesión
COOKIES_PATH=/data/ig_session.json

# Intervalo entre escaneos (minutos)
SCAN_INTERVAL_MIN=90
SCAN_INTERVAL_MAX=120
